# renovate: datasource=github-releases depName=kairos-io/kairos
KAIROS_VERSION=v4.1.2
# renovate: datasource=github-releases depName=kairos-io/kairos-init
KAIROS_INIT_VERSION=v0.15.1
# renovate: datasource=github-releases depName=kairos-io/AuroraBoot
# Pinned: v0.22.0+ dump-source deterministically fails with "failed to
# Lchown ... permission denied" extracting multi-layer images to macOS
# virtiofs bind mounts. Bisected to v0.21.2(good)->v0.22.0(bad); the
# regression rode PR #527's kairos-sdk v0.17->v0.22 bump
# (kairos-io/kairos#3922). Re-test before accepting bumps past v0.21.2.
AURORABOOT_VERSION=v0.21.2
BASE_IMAGE=ubuntu:26.04
# renovate: datasource=github-releases depName=k3s-io/k3s versioning=regex:^v(?<major>\d+)\.(?<minor>\d+)\.(?<patch>\d+)\+k3s(?<build>\d+)$
K3S_VERSION=v1.36.2+k3s1
K2_IMAGE_REVISION=rev1
REGISTRY_IMAGE=ghcr.io/wyvernzora/k2-kairos
