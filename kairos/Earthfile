VERSION 0.8

ARG KAIROS_TARGET="ubuntu-24.04-arm64-rpi4cb-k8s"

#
# Compatibility wrapper: the implementation lives in the root Earthfile
# because k2-tools now builds from the tools Go module.
#
image-build-unit:
    BUILD ../+kairos-image-build-unit

#
# Compatibility wrapper: builds the k2-tools CLI used by Earthly artifact targets.
#
image-build-cli:
    BUILD ../+kairos-image-build-cli

#
# Compatibility wrapper: builds, patches, inspects, and exports Kairos boot artifacts.
#
image-build-artifact:
    ARG KAIROS_TARGET
    BUILD ../+kairos-image-build-artifact --KAIROS_TARGET="$KAIROS_TARGET"
