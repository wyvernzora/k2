{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://k2.wyvernzora.io/schemas/cluster.schema.json",
  "title": "K2 cluster configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "deployPath", "apexDomain", "onePassword", "kubernetes", "argo"],
  "properties": {
    "id": {
      "type": "string",
      "enum": ["legacy"]
    },
    "deployPath": {
      "type": "string",
      "minLength": 1
    },
    "apexDomain": {
      "type": "string",
      "minLength": 1
    },
    "onePassword": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vaultId"],
      "properties": {
        "vaultId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "kubernetes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api", "networking"],
      "properties": {
        "api": {
          "type": "object",
          "additionalProperties": false,
          "required": ["vip", "dnsName", "port", "tlsSans"],
          "properties": {
            "vip": {
              "type": "string",
              "minLength": 1
            },
            "dnsName": {
              "type": "string",
              "minLength": 1
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "tlsSans": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "networking": {
          "type": "object",
          "additionalProperties": false,
          "required": ["podCidr", "serviceCidr", "clusterDns", "clusterDomain"],
          "properties": {
            "podCidr": {
              "type": "string",
              "minLength": 1
            },
            "serviceCidr": {
              "type": "string",
              "minLength": 1
            },
            "clusterDns": {
              "type": "string",
              "minLength": 1
            },
            "clusterDomain": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "argo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "project", "server", "repoUrl", "repoBranch", "autoSync", "syncOptions"],
      "properties": {
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "project": {
          "type": "string",
          "minLength": 1
        },
        "server": {
          "type": "string",
          "minLength": 1
        },
        "repoUrl": {
          "type": "string",
          "minLength": 1
        },
        "repoBranch": {
          "type": "string",
          "minLength": 1
        },
        "appsPath": {
          "type": "string"
        },
        "autoSync": {
          "type": "boolean"
        },
        "applicationNamePrefix": {
          "type": "string"
        },
        "syncOptions": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "boolean"]
          }
        }
      }
    }
  }
}
