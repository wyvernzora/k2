{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "America/Los_Angeles",
  "dependencyDashboard": true,
  "prConcurrentLimit": 8,
  "internalChecksFilter": "strict",
  "minimumReleaseAgeBehaviour": "timestamp-required",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "manual-review"],
    "automerge": false
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automergeType": "pr",
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Wait 7 days before opening PRs for datasources with reliable release timestamps.",
      "matchDatasources": ["npm", "helm", "github-tags", "github-releases"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Wait 7 days for Docker Hub image updates; non-Docker Hub registries often lack tag timestamps.",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "busybox",
        "caddy",
        "eclipse-mosquitto",
        "jesec/flood",
        "koenkk/zigbee2mqtt",
        "linuxserver/homeassistant",
        "n8nio/n8n",
        "node",
        "plexinc/pms-docker",
        "willhallonline/ansible"
      ],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major-update"]
    },
    {
      "description": "Automerge low-risk npm patch updates for development-only tooling after CI passes.",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch"],
      "matchCurrentVersion": "!/^0/",
      "automergeType": "pr",
      "automerge": true
    },
    {
      "description": "Treat cdk8s updates as manifest-affecting even when package.json classifies them as dev tooling.",
      "matchManagers": ["npm"],
      "matchPackageNames": ["cdk8s", "cdk8s-plus-32", "constructs"],
      "groupName": "cdk8s stack",
      "labels": ["risk/medium", "ai-triage"],
      "addLabels": ["cdk8s", "manifest-impact"],
      "automerge": false
    },
    {
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "@stylistic/eslint-plugin",
        "eslint",
        "eslint-config-prettier",
        "eslint-plugin-import-x",
        "eslint-plugin-prettier",
        "typescript-eslint",
        "/^@typescript-eslint\\//"
      ],
      "groupName": "eslint stack",
      "addLabels": ["linting"]
    },
    {
      "matchManagers": ["npm"],
      "matchPackageNames": ["typescript", "tsx", "jiti", "@tsconfig/recommended", "@types/node"],
      "groupName": "typescript tooling",
      "addLabels": ["typescript"]
    },
    {
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "common-tags",
        "debug",
        "dedent-js",
        "fast-glob",
        "find-root",
        "js-yaml",
        "json-stable-stringify",
        "yaml"
      ],
      "groupName": "npm runtime libraries",
      "labels": ["risk/medium", "ai-triage"],
      "addLabels": ["npm-runtime"]
    },
    {
      "description": "CI-only dependencies: automerge once checks pass.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github actions",
      "labels": ["risk/low"],
      "addLabels": ["ci"],
      "automerge": true
    },
    {
      "description": "Tier: medium. App container images referenced from cdk8s source get AI triage via n8n; major bumps included on purpose.",
      "matchDatasources": ["docker"],
      "matchFileNames": ["apps/**", "cdk-lib/**"],
      "labels": ["risk/medium", "ai-triage"],
      "addLabels": ["container"]
    },
    {
      "description": "Tier: low. Utility/sidecar images; minor+patch automerge, majors fall back to the medium tier.",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["busybox", "caddy", "redis"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "utility container images",
      "labels": ["risk/low"],
      "addLabels": ["container", "utility"],
      "automergeType": "pr",
      "automerge": true
    },
    {
      "description": "Tier: low. Own images: a version bump is a release I already cut deliberately.",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/wyvernzora/**"],
      "labels": ["risk/low"],
      "addLabels": ["container"],
      "automergeType": "pr",
      "automerge": true
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/wyvernzora/dmhy-mcp",
        "ghcr.io/wyvernzora/qbittorrent-mcp"
      ],
      "enabled": false
    },
    {
      "description": "Tier: high. Database engine and apps whose majors run irreversible schema migrations.",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/cloudnative-pg/postgresql", "codeberg.org/forgejo/forgejo"],
      "labels": ["risk/high", "manual-review"],
      "addLabels": ["container", "database"],
      "automerge": false
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/paperless-ngx/paperless-ngx"],
      "matchUpdateTypes": ["major"],
      "labels": ["risk/high", "manual-review"],
      "addLabels": ["container", "database"],
      "automerge": false
    },
    {
      "description": "Tier: high by default for helm charts (cluster infrastructure).",
      "matchDatasources": ["helm"],
      "labels": ["risk/high", "manual-review"],
      "addLabels": ["helm", "manifest-impact"],
      "automerge": false
    },
    {
      "description": "Tier: medium. Chart patch releases get AI triage instead of manual review.",
      "matchDatasources": ["helm"],
      "matchUpdateTypes": ["patch"],
      "labels": ["risk/medium", "ai-triage"]
    },
    {
      "description": "Tier: medium. Lower-stakes charts also triage minors.",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["kube-vip", "k8s-gateway"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["risk/medium", "ai-triage"]
    },
    {
      "description": "Tier: high. Node OS / k3s: no manifest diff, but changes what the control plane boots. Blocks the no-diff automerge in build.yaml.",
      "matchFileNames": ["kairos/**"],
      "labels": ["risk/high", "manual-review"],
      "automerge": false
    },
    {
      "description": "Plex tags are 4-part versions plus a build hash (1.43.1.10611-1e34174b1); docker versioning treats the hash as an incompatible suffix, so compare loosely instead.",
      "matchDatasources": ["docker"],
      "matchDepNames": ["plexinc/pms-docker"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+\\.\\d+-[0-9a-f]+$/",
      "versioning": "loose"
    }
  ],
  "ignorePaths": ["**/node_modules/**"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/\\.ts$/"],
      "matchStrings": ["oci`(?<depName>[^`]+):(?<currentValue>[^`]+)`"],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Earthfile$/"],
      "matchStrings": ["FROM\\s+(?<depName>[^\\s:@]+(?:/[^\\s:@]+)*):(?<currentValue>[^\\s$]+)"],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Earthfile$/", "/(^|/)Dockerfile$/", "/(^|/)versions\\.env$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?(?: extractVersion=(?<extractVersion>\\S+))?\\n\\s*(?:ARG |ENV )?\\w+=\"?(?<currentValue>[^\"\\n]+)\"?"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)versions\\.env$/"],
      "matchStrings": ["BASE_IMAGE=(?<depName>[^:\\s]+):(?<currentValue>\\S+)"],
      "datasourceTemplate": "docker",
      "versioningTemplate": "ubuntu"
    }
  ]
}
