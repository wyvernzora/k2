#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/../.." && pwd)"
presets_dir="${script_dir}/k2-vm-presets"
default_artifact_base_url="https://io.wyvernzora.k2.images.s3.us-west-2.amazonaws.com"

usage() {
  cat <<'EOF'
Usage:
  k2-vbox create [preset] [options]
  k2-vbox presets
  k2-vbox list
  k2-vbox info <id|vm-dir>
  k2-vbox start <id|vm-dir>
  k2-vbox stop <id|vm-dir>
  k2-vbox ssh <id|vm-dir>
  k2-vbox enable-console <id|vm-dir> [port|auto]
  k2-vbox console <id|vm-dir>
  k2-vbox delete [--force] <id|vm-dir>

Create options:
  --id <id>                  VM id. Defaults to a random 8-character id.
  --preset <name>            Preset name. Defaults to natnet.
  --raw-xz <path>            Raw .raw.xz artifact to convert. Overrides local/cache/S3 lookup.
  --ssh-port <port|auto>     Override preset SSH host forward.
  --api-port <port|auto>     Override preset Kubernetes API host forward.
  --start                    Start the VM after creation.

Artifact lookup:
  1. --raw-xz path
  2. locally built kairos/artifacts/<target>/*.raw.xz
  3. cached download under kairos/testvm/cache/artifacts/<target>/<git-sha>/
  4. public S3 latest manifest and artifact download

Artifact environment:
  K2_VBOX_ARTIFACT_CACHE      Override downloaded artifact cache directory.
  K2_KAIROS_IMAGE_BASE_URL    Public artifact base URL.
  K2_KAIROS_IMAGE_PREFIX      Optional key prefix inside the artifact bucket.

Default preset:
  natnet

Layout:
  kairos/testvm/vm-<id>/
    kairos-<id>.vdi
    persistent-<id>.vdi
    k2-kairos-<id>/...
EOF
}

die() {
  printf 'k2-vbox: %s\n' "$*" >&2
  exit 1
}

log() {
  printf 'k2-vbox: %s\n' "$*" >&2
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

artifact_cache_root() {
  printf '%s\n' "${K2_VBOX_ARTIFACT_CACHE:-${script_dir}/cache/artifacts}"
}

s3_key() {
  local prefix="$1"
  local suffix="$2"

  prefix="${prefix#/}"
  prefix="${prefix%/}"
  suffix="${suffix#/}"
  if [[ -n "${prefix}" ]]; then
    printf '%s/%s\n' "${prefix}" "${suffix}"
  else
    printf '%s\n' "${suffix}"
  fi
}

artifact_base_url() {
  local base="${K2_KAIROS_IMAGE_BASE_URL:-${default_artifact_base_url}}"
  printf '%s\n' "${base%/}"
}

artifact_url() {
  local key="$1"
  printf '%s/%s\n' "$(artifact_base_url)" "${key#/}"
}

random_id() {
  if command -v uuidgen >/dev/null 2>&1; then
    uuidgen | tr '[:upper:]' '[:lower:]' | tr -d '-' | cut -c1-8
  elif command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 4
  else
    date '+%s' | tail -c 9
  fi
}

vm_dir_for() {
  printf '%s/vm-%s\n' "${script_dir}" "$1"
}

vm_id_from_arg() {
  local arg="$1"
  local trimmed="${arg%/}"
  local base

  base="${trimmed##*/}"
  if [[ "${base}" == vm-* ]]; then
    printf '%s\n' "${base#vm-}"
  else
    printf '%s\n' "${arg}"
  fi
}

vm_name_for() {
  printf 'k2-kairos-%s\n' "$1"
}

metadata_file_for() {
  printf '%s/vm.env\n' "$(vm_dir_for "$1")"
}

quote_value() {
  printf "%q" "$1"
}

write_metadata() {
  local id="$1"
  local file
  file="$(metadata_file_for "${id}")"
  {
    printf 'id=%s\n' "$(quote_value "${id}")"
    printf 'name=%s\n' "$(quote_value "$(vm_name_for "${id}")")"
    printf 'preset=%s\n' "$(quote_value "${preset}")"
    printf 'target=%s\n' "$(quote_value "${target}")"
    printf 'raw_xz=%s\n' "$(quote_value "${raw_xz}")"
    printf 'vm_dir=%s\n' "$(quote_value "$(vm_dir_for "${id}")")"
    printf 'kairos_vdi=%s\n' "$(quote_value "$(vm_dir_for "${id}")/kairos-${id}.vdi")"
    printf 'persistent_vdi=%s\n' "$(quote_value "${persistent_vdi}")"
    printf 'ssh_port=%s\n' "$(quote_value "${ssh_port}")"
    printf 'api_port=%s\n' "$(quote_value "${api_port}")"
    printf 'serial_port=%s\n' "$(quote_value "${serial_port}")"
    printf 'memory_mb=%s\n' "$(quote_value "${memory_mb}")"
    printf 'cpus=%s\n' "$(quote_value "${cpus}")"
    printf 'network_mode=%s\n' "$(quote_value "${network_mode}")"
    printf 'network_name=%s\n' "$(quote_value "${network_name}")"
    printf 'guest_ip=%s\n' "$(quote_value "${guest_ip}")"
    printf 'port_forward_rules=%s\n' "$(quote_value "${port_forward_rules}")"
  } >"${file}"
}

load_metadata() {
  local id="$1"
  local file
  file="$(metadata_file_for "${id}")"
  [[ -f "${file}" ]] || die "unknown VM id ${id}"
  # shellcheck disable=SC1090
  source "${file}"
}

artifact_for_target() {
  local target="$1"
  local artifact

  if artifact="$(local_artifact_for_target "${target}")"; then
    printf '%s\n' "${artifact}"
    return 0
  fi

  if artifact="$(cached_or_downloaded_artifact_for_target "${target}")"; then
    printf '%s\n' "${artifact}"
    return 0
  fi

  die "no local or cached .raw.xz artifact found for ${target}, and latest artifact download failed
Build it locally with:
  earthly --allow-privileged ./kairos+image-build-artifact --KAIROS_TARGET=${target}

Or push a successful main image build so ${target} is available at:
  $(artifact_url "$(s3_key "${K2_KAIROS_IMAGE_PREFIX:-}" "latest/${target}/manifest.json")")"
}

local_artifact_for_target() {
  local target="$1"
  local dir="${repo_root}/kairos/artifacts/${target}"
  local match

  [[ -d "${dir}" ]] || return 1

  if [[ -f "${dir}/artifact-manifest.json" ]]; then
    local manifest_file
    manifest_file="$(node -e 'const fs=require("fs"); const p=process.argv[1]; const m=JSON.parse(fs.readFileSync(p,"utf8")); process.stdout.write(m.compressed?.file || "");' "${dir}/artifact-manifest.json")"
    if [[ -n "${manifest_file}" && -f "${dir}/${manifest_file}" ]]; then
      log "using local artifact ${dir}/${manifest_file}"
      printf '%s\n' "${dir}/${manifest_file}"
      return 0
    fi
  fi

  match="$(find "${dir}" -maxdepth 1 -type f -name '*.raw.xz' | sort | head -n 1)"
  [[ -n "${match}" ]] || return 1
  log "using local artifact ${match}"
  printf '%s\n' "${match}"
}

cached_or_downloaded_artifact_for_target() {
  local target="$1"
  local prefix="${K2_KAIROS_IMAGE_PREFIX:-}"
  local latest_key latest_url cache_root target_cache latest_cache remote_manifest manifest_source

  need curl
  need node
  need shasum

  latest_key="$(s3_key "${prefix}" "latest/${target}/manifest.json")"
  latest_url="$(artifact_url "${latest_key}")"
  cache_root="$(artifact_cache_root)"
  target_cache="${cache_root}/${target}"
  latest_cache="${target_cache}/latest-manifest.json"

  mkdir -p "${target_cache}"

  remote_manifest="$(mktemp)"
  if curl -fsSL "${latest_url}" -o "${remote_manifest}"; then
    cp "${remote_manifest}" "${latest_cache}"
    manifest_source="${remote_manifest}"
    log "resolved latest artifact manifest ${latest_url}"
  elif [[ -f "${latest_cache}" ]]; then
    manifest_source="${latest_cache}"
    log "using cached latest artifact manifest ${latest_cache}"
  else
    rm -f "${remote_manifest}"
    return 1
  fi

  local git_sha image_prefix compressed_file expected_sha artifact_dir artifact_path artifact_key artifact_download_url
  git_sha="$(node -e 'const fs=require("fs"); const m=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(m.git?.sha || "");' "${manifest_source}")"
  image_prefix="$(node -e 'const fs=require("fs"); const m=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(m.s3?.prefix || "");' "${manifest_source}")"
  compressed_file="$(node -e 'const fs=require("fs"); const m=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(m.artifact?.compressed?.file || "");' "${manifest_source}")"
  expected_sha="$(node -e 'const fs=require("fs"); const m=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(m.artifact?.compressed?.sha256 || "");' "${manifest_source}")"
  rm -f "${remote_manifest}"

  [[ -n "${git_sha}" ]] || die "artifact manifest for ${target} is missing git.sha"
  [[ -n "${image_prefix}" ]] || die "artifact manifest for ${target} is missing s3.prefix"
  [[ -n "${compressed_file}" ]] || die "artifact manifest for ${target} is missing artifact.compressed.file"
  [[ -n "${expected_sha}" ]] || die "artifact manifest for ${target} is missing artifact.compressed.sha256"

  artifact_dir="${target_cache}/${git_sha}"
  artifact_path="${artifact_dir}/${compressed_file}"
  if verify_cached_artifact "${artifact_path}" "${expected_sha}"; then
    log "using cached artifact ${artifact_path}"
    printf '%s\n' "${artifact_path}"
    return 0
  fi

  artifact_key="$(s3_key "${image_prefix}" "${compressed_file}")"
  artifact_download_url="$(artifact_url "${artifact_key}")"
  mkdir -p "${artifact_dir}"
  cp "${manifest_source:-${latest_cache}}" "${artifact_dir}/manifest.json" 2>/dev/null || cp "${latest_cache}" "${artifact_dir}/manifest.json" 2>/dev/null || true

  log "downloading ${artifact_download_url}"
  local tmp
  tmp="${artifact_path}.tmp"
  curl -fsSL "${artifact_download_url}" -o "${tmp}"
  mv "${tmp}" "${artifact_path}"

  if ! verify_cached_artifact "${artifact_path}" "${expected_sha}"; then
    rm -f "${artifact_path}"
    die "downloaded artifact checksum mismatch for ${artifact_path}"
  fi

  printf '%s\n' "${artifact_path}"
}

verify_cached_artifact() {
  local path="$1"
  local expected_sha="$2"
  local actual_sha

  [[ -f "${path}" ]] || return 1
  actual_sha="$(shasum -a 256 "${path}" | awk '{ print $1 }')"
  [[ "${actual_sha}" == "${expected_sha}" ]]
}

host_arch() {
  case "$(uname -m)" in
    arm64|aarch64)
      printf 'arm64\n'
      ;;
    x86_64|amd64)
      printf 'amd64\n'
      ;;
    *)
      die "unsupported host architecture $(uname -m); pass --target or --raw-xz explicitly"
      ;;
  esac
}

host_vbox_platform_arch() {
  case "$(host_arch)" in
    arm64)
      printf 'arm\n'
      ;;
    amd64)
      printf 'x86\n'
      ;;
  esac
}

default_qemu_target() {
  printf 'ubuntu-24.04-standard-%s-qemu-k3s\n' "$(host_arch)"
}

list_ostype_ids() {
  local platform_arch="$1"
  VBoxManage list --platform-arch="${platform_arch}" ostypes 2>/dev/null | awk -F: '/^ID:/ { gsub(/^[ \t]+|[ \t]+$/, "", $2); print $2 }'
}

first_matching_ostype() {
  local platform_arch="$1"
  local pattern="$2"
  list_ostype_ids "${platform_arch}" | awk -v pattern="${pattern}" 'tolower($0) ~ pattern { print; exit }'
}

resolve_ostype() {
  local requested="$1"
  local platform_arch="$2"

  case "${requested}" in
    "")
      return 0
      ;;
    host-ubuntu)
      if [[ "${platform_arch}" == "x86" ]]; then
        printf 'Ubuntu_64\n'
        return 0
      fi

      local matched
      matched="$(first_matching_ostype "${platform_arch}" 'ubuntu.*(arm|aarch)')"
      if [[ -n "${matched}" ]]; then
        printf '%s\n' "${matched}"
        return 0
      fi

      # On ARM hosts the platform architecture is the critical bit. If this
      # VirtualBox build does not expose a stable Ubuntu ARM ostype id, omit it
      # instead of accidentally creating an x86 VM.
      return 0
      ;;
    *)
      printf '%s\n' "${requested}"
      ;;
  esac
}

resolve_platform_architecture() {
  local requested="$1"
  case "${requested}" in
    ""|host)
      host_vbox_platform_arch
      ;;
    x86|arm)
      printf '%s\n' "${requested}"
      ;;
    *)
      die "unsupported VirtualBox platform architecture ${requested}; expected host, x86, or arm"
      ;;
  esac
}

preset_path() {
  local name="$1"
  printf '%s/%s.json\n' "${presets_dir}" "${name}"
}

list_presets() {
  need node
  local found="0"
  printf '%-20s %s\n' "PRESET" "DESCRIPTION"
  for file in "${presets_dir}"/*.json; do
    [[ -f "${file}" ]] || continue
    local name description
    name="$(basename "${file}" .json)"
    description="$(node -e 'const fs=require("fs"); const p=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); console.log(p.description || "");' "${file}")"
    printf '%-20s %s\n' "${name}" "${description}"
    found="1"
  done
  [[ "${found}" == "1" ]] || true
}

load_preset() {
  local name="$1"
  local file
  file="$(preset_path "${name}")"
  [[ -f "${file}" ]] || die "unknown preset ${name}; run: kairos/testvm/k2-vbox presets"
  need node

  local env_file
  env_file="$(mktemp)"
  node - "${file}" >"${env_file}" <<'NODE'
const fs = require("fs");
const presetPath = process.argv[2];
const p = JSON.parse(fs.readFileSync(presetPath, "utf8"));

function q(value) {
  return `'${String(value ?? "").replace(/'/g, `'\\''`)}'`;
}
function emit(name, value) {
  console.log(`${name}=${q(value)}`);
}
function bool(value, fallback) {
  return value == null ? fallback : Boolean(value);
}

const target = p.target === "host-qemu" ? "__HOST_QEMU__" : (p.target ?? "");
const persistent = p.persistentDisk ?? {};
const network = p.network ?? {};
const display = p.display ?? {};
const serial = p.serial ?? {};
const forwards = p.forwards ?? [];

emit("preset_description", p.description ?? "");
emit("target", target);
emit("memory_mb", p.memoryMb ?? 4096);
emit("cpus", p.cpus ?? 2);
emit("platform_architecture", p.platformArchitecture ?? "host");
emit("ostype", p.ostype ?? "host-ubuntu");
emit("firmware", p.firmware ?? "efi");
emit("graphics_controller", display.graphicsController ?? "");
emit("vram_mb", display.vramMb ?? "");
emit("serial_enabled", bool(serial.enabled, false) ? "1" : "0");
emit("serial_port", serial.hostPort ?? "");
emit("with_persistent", bool(persistent.enabled, false) ? "1" : "0");
emit("persistent_size_mb", persistent.sizeMb ?? 8192);
emit("network_mode", network.mode ?? "nat");
emit("network_name", network.name ?? "");
emit("network_cidr", network.cidr ?? "");
emit("network_dhcp", bool(network.dhcp, true) ? "1" : "0");
emit("guest_ip", network.guestIp ?? "");
emit("forward_count", forwards.length);

for (let i = 0; i < forwards.length; i++) {
  const f = forwards[i];
  emit(`forward_${i}_name`, f.name ?? `forward-${i}`);
  emit(`forward_${i}_protocol`, f.protocol ?? "tcp");
  emit(`forward_${i}_host_ip`, f.hostIp ?? "127.0.0.1");
  emit(`forward_${i}_host_port`, f.hostPort ?? "");
  emit(`forward_${i}_guest_ip`, f.guestIp ?? "");
  emit(`forward_${i}_guest_port`, f.guestPort ?? "");
}
NODE
  # shellcheck disable=SC1090
  source "${env_file}"
  rm -f "${env_file}"

  if [[ "${target}" == "__HOST_QEMU__" ]]; then
    target="$(default_qemu_target)"
  fi
  platform_architecture="$(resolve_platform_architecture "${platform_architecture}")"
  ostype="$(resolve_ostype "${ostype}" "${platform_architecture}")"
}

port_is_free() {
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    ! lsof -nP -iTCP:"${port}" -sTCP:LISTEN >/dev/null 2>&1
  else
    ! nc -z 127.0.0.1 "${port}" >/dev/null 2>&1
  fi
}

find_free_port() {
  local start="$1"
  local end="$2"
  local port
  for ((port = start; port <= end; port++)); do
    if port_is_free "${port}"; then
      printf '%s\n' "${port}"
      return 0
    fi
  done
  die "no free port found in ${start}-${end}"
}

ensure_vm_absent() {
  local name="$1"
  if VBoxManage showvminfo "${name}" >/dev/null 2>&1; then
    die "VirtualBox VM already exists: ${name}"
  fi
}

natnetwork_prefix() {
  local cidr="$1"
  if [[ "${cidr}" =~ ^([0-9]+\.[0-9]+\.[0-9]+)\.[0-9]+/24$ ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
  else
    die "only /24 NAT network CIDRs are supported: ${cidr}"
  fi
}

ensure_natnetwork_dhcp() {
  local name="$1"
  local cidr="$2"
  local prefix

  prefix="$(natnetwork_prefix "${cidr}")"
  VBoxManage dhcpserver modify \
    "--network=${name}" \
    "--server-ip=${prefix}.2" \
    "--lower-ip=${prefix}.3" \
    "--upper-ip=${prefix}.254" \
    --netmask=255.255.255.0 \
    --enable \
    --global \
    --set-opt=3 "${prefix}.1" \
    --set-opt=6 10.10.10.8 >/dev/null
}

ensure_natnetwork() {
  local name="$1"
  local cidr="$2"
  local dhcp="$3"

  [[ -n "${name}" ]] || die "natnetwork preset requires network.name"
  [[ -n "${cidr}" ]] || die "natnetwork preset requires network.cidr"

  if VBoxManage natnetwork list 2>/dev/null | grep -Eq "^Name:[[:space:]]+${name}$"; then
    local existing_cidr
    existing_cidr="$(VBoxManage natnetwork list | awk -v wanted="${name}" '
      $1 == "Name:" && $2 == wanted { in_network = 1; next }
      in_network && $1 == "Network:" { print $2; exit }
      in_network && $1 == "Name:" { exit }
    ')"
    if [[ -n "${existing_cidr}" && "${existing_cidr}" != "${cidr}" ]]; then
      die "NAT network ${name} already exists with CIDR ${existing_cidr}, but preset wants ${cidr}
Delete or rename the existing VirtualBox NAT network before creating more VMs:
  VBoxManage natnetwork remove --netname ${name}"
    fi
    VBoxManage natnetwork modify --netname "${name}" --enable
    if [[ "${dhcp}" == "1" ]]; then
      VBoxManage natnetwork modify --netname "${name}" --dhcp on
      ensure_natnetwork_dhcp "${name}" "${cidr}"
    else
      VBoxManage natnetwork modify --netname "${name}" --dhcp off
    fi
    return
  fi

  local dhcp_arg="off"
  [[ "${dhcp}" == "1" ]] && dhcp_arg="on"
  log "creating NAT network ${name} (${cidr})"
  VBoxManage natnetwork add --netname "${name}" --network "${cidr}" --enable --dhcp "${dhcp_arg}"
  if [[ "${dhcp}" == "1" ]]; then
    ensure_natnetwork_dhcp "${name}" "${cidr}"
  fi
}

resolve_forward_port() {
  local spec="$1"
  if [[ "${spec}" =~ ^auto:([0-9]+)-([0-9]+)$ ]]; then
    find_free_port "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
  elif [[ "${spec}" == "auto" ]]; then
    find_free_port 20000 20999
  else
    printf '%s\n' "${spec}"
  fi
}

network_prefix() {
  local cidr="$1"
  if [[ "${cidr}" =~ ^([0-9]+\.[0-9]+\.[0-9]+)\.[0-9]+/24$ ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
  else
    die "only /24 NAT network CIDRs are supported for automatic guest IPs: ${cidr}"
  fi
}

guest_ip_in_use() {
  local candidate="$1"
  local file line existing
  for file in "${script_dir}"/vm-*/vm.env; do
    [[ -f "${file}" ]] || continue
    line="$(grep -E '^guest_ip=' "${file}" | tail -n 1 || true)"
    existing="${line#guest_ip=}"
    if [[ "${existing}" == "${candidate}" ]]; then
      return 0
    fi
  done
  return 1
}

allocate_guest_ip() {
  local id="$1"
  local cidr="$2"
  local prefix start offset candidate

  prefix="$(network_prefix "${cidr}")"
  start="$(printf '%s' "${id}" | cksum | awk '{ print ($1 % 200) + 20 }')"

  for ((offset = 0; offset < 200; offset++)); do
    candidate="${prefix}.$(( ((start - 20 + offset) % 200) + 20 ))"
    if ! guest_ip_in_use "${candidate}"; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  die "no free guest IP found in ${cidr}"
}

natnetwork_endpoint() {
  local value="$1"
  if [[ -n "${value}" ]]; then
    printf '[%s]' "${value}"
  else
    printf '[]'
  fi
}

apply_network() {
  local name="$1"

  case "${network_mode}" in
    nat)
      VBoxManage modifyvm "${name}" --nic1 nat
      ;;
    natnetwork)
      ensure_natnetwork "${network_name}" "${network_cidr}" "${network_dhcp}"
      VBoxManage modifyvm "${name}" --nic1 natnetwork --nat-network1 "${network_name}"
      ;;
    *)
      die "unsupported preset network mode ${network_mode}"
      ;;
  esac
}

apply_serial_console() {
  local vm_name="$1"

  if [[ "${serial_enabled}" != "1" ]]; then
    return
  fi

  [[ -n "${serial_port}" ]] || die "serial console is enabled but serial.hostPort is empty"
  serial_port="$(resolve_forward_port "${serial_port}")"
  VBoxManage modifyvm "${vm_name}" --uart1 0x3F8 4 --uart-mode1 tcpserver "${serial_port}" --uart-type1 16550A
}

configure_guest_ip() {
  local vm_name="$1"

  if [[ "${network_mode}" != "natnetwork" ]]; then
    return
  fi

  if [[ "${guest_ip}" == "auto" ]]; then
    die "guest_ip was not resolved before configuring NAT network DHCP"
  fi
  [[ -n "${guest_ip}" ]] || die "NAT network port forwarding requires a guest IP"

  log "reserving ${guest_ip} for ${vm_name} on ${network_name}"
  VBoxManage dhcpserver modify \
    "--network=${network_name}" \
    "--vm=${vm_name}" \
    --nic=1 \
    "--fixed-address=${guest_ip}"
}

delete_natnetwork_forward() {
  local network="$1"
  local rule="$2"
  VBoxManage natnetwork modify --netname "${network}" --port-forward-4 delete "${rule}" >/dev/null 2>&1 || true
}

delete_natnetwork_dhcp_config() {
  local network="$1"
  local vm="$2"
  VBoxManage dhcpserver modify "--network=${network}" "--vm=${vm}" --nic=1 --remove-config >/dev/null 2>&1 || true
}

apply_forwards() {
  local id="$1"
  local vm_name="$2"
  local forward_ssh_port=""
  local forward_api_port=""
  port_forward_rules=""

  for ((i = 0; i < forward_count; i++)); do
    local name_var="forward_${i}_name"
    local protocol_var="forward_${i}_protocol"
    local host_ip_var="forward_${i}_host_ip"
    local host_port_var="forward_${i}_host_port"
    local guest_ip_var="forward_${i}_guest_ip"
    local guest_port_var="forward_${i}_guest_port"

    local forward_name="${!name_var}"
    local protocol="${!protocol_var}"
    local host_ip="${!host_ip_var}"
    local host_port="${!host_port_var}"
    local guest_ip="${!guest_ip_var}"
    local guest_port="${!guest_port_var}"

    case "${forward_name}" in
      ssh)
        if [[ "${ssh_port}" != "auto" ]]; then
          host_port="${ssh_port}"
        fi
        ;;
      k8s-api)
        if [[ "${api_port}" != "auto" ]]; then
          host_port="${api_port}"
        fi
        ;;
    esac

    host_port="$(resolve_forward_port "${host_port}")"
    [[ -n "${guest_port}" ]] || die "forward ${forward_name} missing guestPort"

    local rule_name="${forward_name}-${id}"
    if [[ "${network_mode}" == "natnetwork" ]]; then
      if [[ -z "${guest_ip}" ]]; then
        guest_ip="${guest_ip:-${GLOBALS_GUEST_IP:-}}"
      fi
      [[ -n "${guest_ip}" ]] || die "NAT network forward ${forward_name} requires a concrete guest IP"
      delete_natnetwork_forward "${network_name}" "${rule_name}"
      local nat_host_ip nat_guest_ip
      nat_host_ip="$(natnetwork_endpoint "${host_ip}")"
      nat_guest_ip="$(natnetwork_endpoint "${guest_ip}")"
      VBoxManage natnetwork modify \
        --netname "${network_name}" \
        --port-forward-4 "${rule_name}:${protocol}:${nat_host_ip}:${host_port}:${nat_guest_ip}:${guest_port}"
    else
      if [[ -n "${guest_ip}" ]]; then
        VBoxManage modifyvm "${vm_name}" --natpf1 "${rule_name},${protocol},${host_ip},${host_port},${guest_ip},${guest_port}"
      else
        VBoxManage modifyvm "${vm_name}" --natpf1 "${rule_name},${protocol},${host_ip},${host_port},,${guest_port}"
      fi
    fi
    port_forward_rules="${port_forward_rules}${port_forward_rules:+ }${rule_name}"

    case "${forward_name}" in
      ssh)
        forward_ssh_port="${host_port}"
        ;;
      k8s-api)
        forward_api_port="${host_port}"
        ;;
    esac
  done

  ssh_port="${forward_ssh_port:-${ssh_port}}"
  api_port="${forward_api_port:-${api_port}}"
}

create_vm() {
  need VBoxManage
  need xz

  preset="natnet"
  local id=""
  raw_xz=""
  ssh_port="auto"
  api_port="auto"
  local start_after="0"

  if [[ $# -gt 0 && "${1}" != --* ]]; then
    preset="$1"
    shift
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id)
        id="$2"
        shift 2
        ;;
      --preset)
        preset="$2"
        shift 2
        ;;
      --raw-xz)
        raw_xz="$2"
        shift 2
        ;;
      --ssh-port)
        ssh_port="$2"
        shift 2
        ;;
      --api-port)
        api_port="$2"
        shift 2
        ;;
      --start)
        start_after="1"
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown create option: $1"
        ;;
    esac
  done

  load_preset "${preset}"

  [[ "${firmware}" == "efi" || "${firmware}" == "bios" ]] || die "--firmware must be efi or bios"
  [[ -n "${id}" ]] || id="$(random_id)"
  [[ "${id}" =~ ^[a-zA-Z0-9._-]+$ ]] || die "id contains unsupported characters: ${id}"

  local vm_dir name kairos_vdi raw_tmp
  vm_dir="$(vm_dir_for "${id}")"
  name="$(vm_name_for "${id}")"
  kairos_vdi="${vm_dir}/kairos-${id}.vdi"
  persistent_vdi=""

  [[ ! -e "${vm_dir}" ]] || die "VM directory already exists: ${vm_dir}"
  ensure_vm_absent "${name}"

  log "using preset ${preset}: ${preset_description}"
  log "using target ${target}"
  log "using VirtualBox platform architecture ${platform_architecture}"
  if [[ "${network_mode}" == "natnetwork" && "${guest_ip}" == "auto" ]]; then
    guest_ip="$(allocate_guest_ip "${id}" "${network_cidr}")"
  fi
  GLOBALS_GUEST_IP="${guest_ip}"
  if [[ -n "${guest_ip}" ]]; then
    log "using guest IP ${guest_ip}"
  fi
  if [[ -n "${ostype}" ]]; then
    log "using VirtualBox OS type ${ostype}"
  fi
  if [[ -z "${raw_xz}" ]]; then
    raw_xz="$(artifact_for_target "${target}")"
  fi
  [[ -f "${raw_xz}" ]] || die "raw artifact not found: ${raw_xz}"

  if [[ "${ssh_port}" == "auto" ]]; then
    ssh_port="$(find_free_port 2222 2299)"
  fi
  if [[ "${api_port}" == "auto" ]]; then
    api_port="$(find_free_port 6443 6543)"
  fi
  if [[ "${serial_enabled}" == "1" && "${serial_port}" == "auto" ]]; then
    serial_port="$(find_free_port 23000 23999)"
  fi

  mkdir -p "${vm_dir}"
  raw_tmp="${vm_dir}/kairos-${id}.raw"

  log "expanding ${raw_xz}"
  xz -dc "${raw_xz}" >"${raw_tmp}"
  log "converting raw image to ${kairos_vdi}"
  VBoxManage convertfromraw "${raw_tmp}" "${kairos_vdi}" --format VDI
  rm -f "${raw_tmp}"

  if [[ "${with_persistent}" == "1" ]]; then
    persistent_vdi="${vm_dir}/persistent-${id}.vdi"
    log "creating persistent disk ${persistent_vdi}"
    VBoxManage createmedium disk --filename "${persistent_vdi}" --size "${persistent_size_mb}" --format VDI
  fi

  log "creating VM ${name}"
  local create_args=(createvm --name "${name}" "--platform-architecture=${platform_architecture}" --basefolder "${vm_dir}" --register)
  if [[ -n "${ostype}" ]]; then
    create_args+=(--ostype "${ostype}")
  fi
  VBoxManage "${create_args[@]}"
  VBoxManage modifyvm "${name}" \
    --memory "${memory_mb}" \
    --cpus "${cpus}" \
    --firmware "${firmware}" \
    --boot1 disk \
    --boot2 none \
    --boot3 none \
    --boot4 none
  if [[ -n "${graphics_controller}" ]]; then
    VBoxManage modifyvm "${name}" --graphicscontroller "${graphics_controller}"
  fi
  if [[ -n "${vram_mb}" ]]; then
    VBoxManage modifyvm "${name}" --vram "${vram_mb}"
  fi
  apply_network "${name}"
  apply_serial_console "${name}"
  configure_guest_ip "${name}"
  apply_forwards "${id}" "${name}"
  VBoxManage storagectl "${name}" --name "SATA" --add sata --controller IntelAhci --portcount 2
  VBoxManage storageattach "${name}" --storagectl "SATA" --port 0 --device 0 --type hdd --medium "${kairos_vdi}"
  if [[ -n "${persistent_vdi}" ]]; then
    VBoxManage storageattach "${name}" --storagectl "SATA" --port 1 --device 0 --type hdd --medium "${persistent_vdi}"
  fi

  write_metadata "${id}"

  log "created ${name}"
  log "directory: ${vm_dir}"
  log "ssh: ssh -p ${ssh_port} kairos@127.0.0.1"
  [[ -n "${api_port}" ]] && log "api: https://127.0.0.1:${api_port}"
  [[ -n "${serial_port:-}" ]] && log "console: ${script_dir}/k2-vbox console ${id}"

  if [[ "${start_after}" == "1" ]]; then
    start_vm "${id}"
  fi
}

list_vms() {
  local found="0"
  printf '%-12s %-20s %-28s %-8s %-8s %s\n' "ID" "PRESET" "NAME" "SSH" "API" "DIR"
  for dir in "${script_dir}"/vm-*; do
    [[ -d "${dir}" ]] || continue
    local id
    id="$(basename "${dir}" | sed 's/^vm-//')"
    [[ -f "$(metadata_file_for "${id}")" ]] || continue
    load_metadata "${id}"
    printf '%-12s %-20s %-28s %-8s %-8s %s\n' "${id}" "${preset:-unknown}" "${name}" "${ssh_port}" "${api_port}" "${vm_dir}"
    found="1"
  done
  [[ "${found}" == "1" ]] || true
}

info_vm() {
  local id
  id="$(vm_id_from_arg "$1")"
  load_metadata "${id}"
  printf 'id=%s\nname=%s\npreset=%s\ntarget=%s\nraw_xz=%s\nvm_dir=%s\nkairos_vdi=%s\npersistent_vdi=%s\nssh_port=%s\napi_port=%s\nserial_port=%s\nmemory_mb=%s\ncpus=%s\nnetwork_mode=%s\nnetwork_name=%s\nguest_ip=%s\n' \
    "${id}" "${name}" "${preset:-unknown}" "${target}" "${raw_xz}" "${vm_dir}" "${kairos_vdi}" "${persistent_vdi}" "${ssh_port}" "${api_port}" "${serial_port:-}" "${memory_mb}" "${cpus}" "${network_mode:-}" "${network_name:-}" "${guest_ip:-}"
}

start_vm() {
  need VBoxManage
  local id
  id="$(vm_id_from_arg "$1")"
  load_metadata "${id}"
  VBoxManage startvm "${name}" --type "${K2_VBOX_START_TYPE:-headless}"
}

stop_vm() {
  need VBoxManage
  local id
  id="$(vm_id_from_arg "$1")"
  load_metadata "${id}"
  VBoxManage controlvm "${name}" acpipowerbutton
}

ssh_vm() {
  local id
  id="$(vm_id_from_arg "$1")"
  load_metadata "${id}"
  printf 'ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p %s kairos@127.0.0.1\n' "${ssh_port}"
}

enable_console_vm() {
  need VBoxManage
  local id requested_port
  id="$(vm_id_from_arg "$1")"
  requested_port="${2:-auto:23000-23999}"
  load_metadata "${id}"

  serial_port="$(resolve_forward_port "${requested_port}")"
  VBoxManage modifyvm "${name}" --uart1 0x3F8 4 --uart-mode1 tcpserver "${serial_port}" --uart-type1 16550A
  write_metadata "${id}"
  log "enabled ${name} serial console on 127.0.0.1:${serial_port}"
  log "connect with: ${script_dir}/k2-vbox console ${id}"
}

console_vm() {
  need nc
  local id
  id="$(vm_id_from_arg "$1")"
  load_metadata "${id}"
  [[ -n "${serial_port:-}" ]] || die "VM ${id} has no serial console configured"
  log "connecting to ${name} serial console on 127.0.0.1:${serial_port}; press Ctrl-C to detach"
  exec nc 127.0.0.1 "${serial_port}"
}

delete_vm() {
  need VBoxManage

  local force="0"
  if [[ "${1:-}" == "--force" ]]; then
    force="1"
    shift
  fi
  [[ $# -eq 1 ]] || die "delete requires <id|vm-dir>"

  local id
  id="$(vm_id_from_arg "$1")"
  load_metadata "${id}"

  if [[ "${force}" != "1" ]]; then
    printf 'Delete VM %s and %s? [y/N] ' "${name}" "${vm_dir}" >&2
    local answer
    read -r answer
    [[ "${answer}" == "y" || "${answer}" == "Y" ]] || die "delete cancelled"
  fi

  VBoxManage controlvm "${name}" poweroff >/dev/null 2>&1 || true
  if [[ "${network_mode:-}" == "natnetwork" && -n "${network_name:-}" && -n "${port_forward_rules:-}" ]]; then
    for rule in ${port_forward_rules}; do
      delete_natnetwork_forward "${network_name}" "${rule}"
    done
  fi
  if [[ "${network_mode:-}" == "natnetwork" && -n "${network_name:-}" ]]; then
    delete_natnetwork_dhcp_config "${network_name}" "${name}"
  fi
  VBoxManage unregistervm "${name}" --delete >/dev/null 2>&1 || true
  rm -rf "${vm_dir}"
  log "deleted ${id}"
}

main() {
  local cmd="${1:-}"
  case "${cmd}" in
    create)
      shift
      create_vm "$@"
      ;;
    presets)
      shift
      [[ $# -eq 0 ]] || die "presets takes no arguments"
      list_presets
      ;;
    list)
      shift
      [[ $# -eq 0 ]] || die "list takes no arguments"
      list_vms
      ;;
    info)
      shift
      [[ $# -eq 1 ]] || die "info requires <id|vm-dir>"
      info_vm "$1"
      ;;
    start)
      shift
      [[ $# -eq 1 ]] || die "start requires <id|vm-dir>"
      start_vm "$1"
      ;;
    stop)
      shift
      [[ $# -eq 1 ]] || die "stop requires <id|vm-dir>"
      stop_vm "$1"
      ;;
    ssh)
      shift
      [[ $# -eq 1 ]] || die "ssh requires <id|vm-dir>"
      ssh_vm "$1"
      ;;
    enable-console)
      shift
      [[ $# -eq 1 || $# -eq 2 ]] || die "enable-console requires <id|vm-dir> [port|auto]"
      enable_console_vm "$@"
      ;;
    console)
      shift
      [[ $# -eq 1 ]] || die "console requires <id|vm-dir>"
      console_vm "$1"
      ;;
    delete)
      shift
      delete_vm "$@"
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      die "unknown command: ${cmd}"
      ;;
  esac
}

main "$@"
