{
  "target": "ubuntu-24.04-standard-arm64-qemu-k3s",
  "enabled": true,
  "flavor": "ubuntu",
  "flavorRelease": "24.04",
  "variant": "standard",
  "arch": "arm64",
  "platform": "linux/arm64",
  "hardware": "qemu",
  "kairosModel": "generic",
  "kubernetesDistro": "k3s",
  "artifacts": [
    "raw"
  ],
  "overlays": [
    "hardware/qemu",
    "kubernetes/k3s"
  ],
  "rawPatches": null,
  "inspection": {
    "oci": {
      "files": [
        {
          "source": "overlay:hardware/qemu",
          "path": "/system/oem/05-qemu-persistent.yaml",
          "contains": [
            "QEMU required second-disk COS_PERSISTENT",
            "kairos-qemu-persistent"
          ]
        },
        {
          "source": "overlay:kubernetes/k3s",
          "path": "/usr/share/k2/node-provision/k3s/10-k2-invariant.yaml",
          "contains": [
            "flannel-backend: none",
            "disable-kube-proxy: true",
            "secrets-encryption-provider: secretbox"
          ]
        },
        {
          "source": "overlay:kubernetes/k3s",
          "path": "/usr/share/k2/node-provision/k3s/README.md",
          "contains": [
            "K2 K3s Node Provisioning Overlay",
            "Active cluster-specific K3s configuration is written at provision time"
          ]
        }
      ],
      "absent": [
        {
          "source": "overlay:kubernetes/k3s",
          "path": "/etc/rancher/k3s/config.yaml"
        },
        {
          "source": "overlay:kubernetes/k3s",
          "path": "/etc/rancher/k3s/config.yaml.d/10-k2-invariant.yaml"
        },
        {
          "source": "overlay:kubernetes/k3s",
          "path": "/etc/rancher/k3s/config.yaml.d/20-k2-intent.yaml"
        },
        {
          "source": "overlay:hardware/qemu",
          "path": "/system/oem/05-rpi4cb-nvme-persistent.yaml"
        },
        {
          "source": "overlay:hardware/qemu",
          "path": "/system/oem/20-rpi4cb-nvme-data.yaml"
        },
        {
          "source": "overlay:kubernetes/k3s",
          "path": "/system/oem/30-k2-k3s-provider.yaml"
        }
      ],
      "commands": [
        {
          "source": "overlay:hardware/qemu",
          "name": "parted"
        },
        {
          "source": "overlay:hardware/qemu",
          "name": "resize2fs"
        }
      ]
    },
    "raw": {}
  },
  "artifactOptions": {
    "raw": {
      "diskStateSize": 4096,
      "diskSize": 8192
    }
  },
  "image": "ghcr.io/wyvernzora/k2-kairos:ubuntu-24.04-standard-v4.1.0-arm64-qemu-k3s-v1.36.0-k3s1-rev0",
  "artifactStem": "ubuntu-24.04-standard-v4.1.0-arm64-qemu-k3s-v1.36.0-k3s1-rev0",
  "artifactDir": "$FIXTURE/kairos/artifacts/ubuntu-24.04-standard-arm64-qemu-k3s",
  "versions": {
    "kairosVersion": "v4.1.0",
    "kairosInitVersion": "v0.13.0",
    "aurorabootVersion": "v0.19.4",
    "baseImage": "ubuntu:24.04",
    "k3sVersion": "v1.36.0+k3s1",
    "imageRevision": "rev0",
    "registryImage": "ghcr.io/wyvernzora/k2-kairos"
  },
  "paths": {
    "buildRoot": "$FIXTURE/kairos",
    "kairosRoot": "$FIXTURE/kairos",
    "targetsFile": "$FIXTURE/kairos/targets.yaml",
    "versionsFile": "$FIXTURE/kairos/versions.env",
    "overlaysDir": "$FIXTURE/kairos/overlays",
    "artifactsDir": "$FIXTURE/kairos/artifacts"
  }
}
