# macOS files
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two trailing dots
._*

# Thumbnails
Thumbs.db

# Node.js dependencies
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Typescript compiled output
dist/
out/

# Python bytecode
__pycache__/
*.py[cod]

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.envrc

# IDE and Editor directories
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# Claude Code agent state
# Tracked:  .claude/{settings.json,hooks/,commands/,skills/,agents/,CLAUDE.md}
# Ignored:  user-local config overrides, runtime locks, checkpoint notes
.checkpoint/
.claude/*.local.json
.claude/*.lock

# Cross-branch reference worktree (git worktree add .main main)
/.main/

# Logs
logs/
*.log

# Coverage
coverage/
*.lcov

# Private notes
notes/

# Other files to ignore
.nx
*.tsbuildinfo
.tmp-earthly-out

# Kairos image build local artifacts
/kairos/artifacts/
/kairos/notes/
/kairos/testvm/
/k2/.testvm/
/.testvm/
/kairos/vm/
/tools/k2-tools

# k8s manifest output destination
/deploy/
deploy.diff
deploy-diff.md

# Helm dependency management artifacts
# Chart versions are always fully pinned so lock file is not necessary
/apps/*/charts
/apps/*/Chart.lock

# CRD constructs generated by cdk8s
/apps/*/crds/*.ts
/packages/*/crds/*.ts
