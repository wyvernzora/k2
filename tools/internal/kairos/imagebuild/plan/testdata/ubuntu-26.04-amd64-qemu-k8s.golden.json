        {
          "source": "overlay:hardware/qemu",
          "path": "/system/oem/06-qemu-serial-console.yaml"
        },
        {
          "source": "overlay:role/k8s",
          "path": "/system/oem/30-k2-k3s-provider.yaml"
        }
      ],
      "commands": [
        {
          "source": "overlay:role/k8s",
          "name": "k2-node-agent"
        },
        {
          "source": "overlay:role/k8s",
          "name": "parted"
        },
        {
          "source": "overlay:hardware/qemu",
